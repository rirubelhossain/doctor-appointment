generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Appointment {
  id          Int      @id @default(autoincrement())
  fullName    String
  email       String
  phone       String
  doctor      String
  appointment DateTime
  message     String?
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
}